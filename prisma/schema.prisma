generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// MODÈLES
// ─────────────────────────────────────────────

model Abonnement {
  id                     Int       @id @default(autoincrement())
  id_ecole               Int
  stripe_subscription_id String?
  status                 String?
  current_period_end     DateTime?
  ecole                  Ecole     @relation(fields: [id_ecole], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_ecole])
  @@map("abonnements")
}

model Absence {
  id           Int            @id @default(autoincrement())
  id_eleve     Int
  date_absence DateTime
  statut       AbsenceStatut? @default(non_justifie)
  motif        String?
  user         User           @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_eleve])
  @@map("absences")
}

model Admin {
  IDadmin      Int    @id @default(autoincrement())
  email        String
  mot_de_passe String

  @@map("admin")
}

model AIInsight {
  id              Int      @id @default(autoincrement())
  id_utilisateur  Int
  type            String
  message         String
  score_confiance Decimal?
  created_at      DateTime @default(now())
  user            User     @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_utilisateur])
  @@map("ai_insights")
}

model Annonce {
  id            Int          @id @default(autoincrement())
  titre         String
  message       String
  cible         AnnonceCible @default(tous)
  id_auteur     Int
  date_creation DateTime     @default(now())
  user          User         @relation(fields: [id_auteur], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_auteur])
  @@map("annonces")
}

model Badge {
  id            Int          @id @default(autoincrement())
  nom           String
  description   String?
  icon_name     String?      @default("Award")
  points_requis Int?         @default(0)
  eleveBadges   EleveBadge[]

  @@map("badges")
}

model Class {
  id             Int             @id @default(autoincrement())
  id_ecole       Int?
  nom            String
  niveau         String
  created_at     DateTime        @default(now())
  ecole          Ecole?          @relation(fields: [id_ecole], references: [id], onUpdate: Restrict)
  emploisDuTemps EmploiDuTemps[]
  evaluations    Evaluation[]
  inscriptions   Inscription[]

  @@index([id_ecole])
  @@map("classes")
}

model Ecole {
  id                 Int          @id @default(autoincrement())
  nom                String
  subdomain          String?      @unique
  logo_url           String?
  stripe_customer_id String?
  plan               EcolePlan?   @default(gratuit)
  database_url       String?
  db_status          String       @default("ready")
  created_at         DateTime     @default(now())
  abonnements        Abonnement[]
  classes            Class[]
  users              User[]

  @@map("ecoles")
}

model EleveBadge {
  id             Int      @id @default(autoincrement())
  id_eleve       Int
  id_badge       Int
  date_obtention DateTime @default(now())
  user           User     @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict)
  badge          Badge    @relation(fields: [id_badge], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_badge])
  @@index([id_eleve])
  @@map("eleve_badges")
}

model Eleve {
  IDeleves Int @id @default(autoincrement())

  @@map("eleves")
}

model EmploiDuTemps {
  id            Int      @id @default(autoincrement())
  id_classe     Int
  id_enseignant Int
  matiere       String
  jour          Jour
  heure_debut   DateTime
  heure_fin     DateTime
  salle         String?
  classe        Class    @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user          User     @relation(fields: [id_enseignant], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_classe])
  @@index([id_enseignant])
  @@map("emplois_du_temps")
}

model Enseignant {
  IDenseign Int @id @default(autoincrement())

  @@map("enseignants")
}

model Evaluation {
  id        Int       @id @default(autoincrement())
  id_classe Int
  matiere   String
  date_eval DateTime
  type_eval TypeEval? @default(devoir)
  bareme    Int?      @default(20)
  periode   String?
  classe    Class     @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict)
  notes     Note[]

  @@index([id_classe])
  @@map("evaluations")
}

model Inscription {
  id             Int    @id @default(autoincrement())
  id_eleve       Int
  id_classe      Int
  annee_scolaire String
  user           User   @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict)
  classe         Class  @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_classe])
  @@index([id_eleve])
  @@map("inscriptions")
}

model Message {
  id              Int      @id @default(autoincrement())
  id_expediteur   Int
  id_destinataire Int
  contenu         String
  lu              Boolean  @default(false)
  created_at      DateTime @default(now())
  destinataire    User     @relation("MessageDestinataire", fields: [id_destinataire], references: [id], onDelete: Cascade)
  expediteur      User     @relation("MessageExpediteur", fields: [id_expediteur], references: [id], onDelete: Cascade)

  @@index([id_destinataire])
  @@index([id_expediteur])
  @@map("messages")
}

model Note {
  id            Int        @id @default(autoincrement())
  id_evaluation Int
  id_eleve      Int
  valeur        Decimal
  commentaire   String?
  evaluation    Evaluation @relation(fields: [id_evaluation], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user          User       @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_eleve])
  @@index([id_evaluation])
  @@map("notes")
}

model Paiement {
  id             Int            @id @default(autoincrement())
  id_utilisateur Int
  montant        Decimal
  status         PaiementStatus @default(en_attente)
  type           PaiementType
  date_paiement  DateTime       @default(now())
  user           User           @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_utilisateur])
  @@map("paiements")
}

model ParcoursScolaire {
  id               Int               @id @default(autoincrement())
  id_eleve         Int
  annee_scolaire   String
  classe_nom       String
  moyenne_generale Decimal?
  resultat         ParcoursResultat? @default(Admis)
  observations     String?
  user             User              @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([id_eleve])
  @@map("parcours_scolaires")
}

model ParentEleve {
  id        Int  @id @default(autoincrement())
  id_parent Int
  id_eleve  Int
  eleve     User @relation("ParentEleveEleve", fields: [id_eleve], references: [id], onDelete: Cascade)
  parent    User @relation("ParentEleveParent", fields: [id_parent], references: [id], onDelete: Cascade)

  @@index([id_eleve])
  @@index([id_parent])
  @@map("parent_eleve")
}

model Parent {
  IDparents Int @id @default(autoincrement())

  @@map("parents")
}

model Setting {
  id       Int     @id @default(autoincrement())
  key_name String  @unique
  value    String?

  @@map("settings")
}

model User {
  id                  Int                @id @default(autoincrement())
  id_ecole            Int?
  nom                 String
  email               String             @unique
  password            String
  role                Role
  matiere             String?
  points              Int                @default(0)
  niveau              Int                @default(1)
  created_at          DateTime           @default(now())
  absences            Absence[]
  aiInsights          AIInsight[]
  annonces            Annonce[]
  eleveBadges         EleveBadge[]
  emploisDuTemps      EmploiDuTemps[]
  inscriptions        Inscription[]
  messagesRecus       Message[]          @relation("MessageDestinataire")
  messagesEnvoyes     Message[]          @relation("MessageExpediteur")
  notes               Note[]
  paiements           Paiement[]
  parcoursScolaires   ParcoursScolaire[]
  parentEleveAsEleve  ParentEleve[]      @relation("ParentEleveEleve")
  parentEleveAsParent ParentEleve[]      @relation("ParentEleveParent")
  ecole               Ecole?             @relation(fields: [id_ecole], references: [id], onUpdate: Restrict)

  @@index([id_ecole])
  @@map("users")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AbsenceStatut {
  justifie
  non_justifie
  en_attente

  @@map("absences_statut")
}

enum AnnonceCible {
  tous
  enseignants
  parents
  eleves

  @@map("annonces_cible")
}

enum PaiementStatus {
  paye
  en_attente
  annule

  @@map("paiements_status")
}

enum Jour {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi

  @@map("emplois_du_temps_jour")
}

enum TypeEval {
  devoir
  examen
  controle

  @@map("evaluations_type_eval")
}

enum PaiementType {
  scolarite
  inscription
  examen

  @@map("paiements_type")
}

enum EcolePlan {
  gratuit
  standard
  premium

  @@map("ecoles_plan")
}

enum ParcoursResultat {
  Admis
  Redoublant
  Exclu
  Transfert

  @@map("parcours_scolaires_resultat")
}

enum Role {
  admin
  teacher
  parent
  student

  @@map("users_role")
}
