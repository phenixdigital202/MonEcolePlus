generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  id_ecole           Int?
  nom                String               @db.VarChar(100)
  email              String               @unique(map: "email") @db.VarChar(255)
  password           String               @db.VarChar(255)
  role               Role
  matiere            String?              @db.VarChar(100)
  points             Int                  @default(0)
  niveau             Int                  @default(1)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  absences           Absence[]
  ai_insights        ai_insights[]
  annonces           annonces[]
  eleve_badges       eleve_badges[]
  emplois_du_temps   emplois_du_temps[]
  inscriptions       Inscription[]
  received_messages  Message[]            @relation("received_messages")
  sent_messages      Message[]            @relation("sent_messages")
  notes              notes[]
  paiements          Paiement[]
  parcours_scolaires parcours_scolaires[]
  student_links      parent_eleve[]       @relation("student")
  parent_links       parent_eleve[]       @relation("parent")
  ecoles             ecoles?              @relation(fields: [id_ecole], references: [id], onUpdate: Restrict, map: "fk_user_ecole")

  @@index([id_ecole], map: "fk_user_ecole")
  @@map("users")
}

model Message {
  id              Int      @id @default(autoincrement())
  id_expediteur   Int
  id_destinataire Int
  contenu         String   @db.Text
  lu              Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  destinataire    User     @relation("received_messages", fields: [id_destinataire], references: [id], onDelete: Cascade)
  expediteur      User     @relation("sent_messages", fields: [id_expediteur], references: [id], onDelete: Cascade)

  @@index([id_expediteur], map: "id_expediteur")
  @@index([id_destinataire], map: "id_destinataire")
  @@map("messages")
}

model parent_eleve {
  id        Int  @id @default(autoincrement())
  id_parent Int
  id_eleve  Int
  eleve     User @relation("student", fields: [id_eleve], references: [id], onDelete: Cascade)
  parent    User @relation("parent", fields: [id_parent], references: [id], onDelete: Cascade)

  @@index([id_parent], map: "id_parent")
  @@index([id_eleve], map: "id_eleve")
  @@map("parent_eleve")
}

model Class {
  id               Int                @id @default(autoincrement())
  id_ecole         Int?
  nom              String             @db.VarChar(50)
  niveau           String             @db.VarChar(50)
  created_at       DateTime           @default(now()) @db.Timestamp(0)
  ecoles           ecoles?            @relation(fields: [id_ecole], references: [id], onUpdate: Restrict, map: "fk_classe_ecole")
  emplois_du_temps emplois_du_temps[]
  evaluations      evaluations[]
  inscriptions     Inscription[]

  @@index([id_ecole], map: "fk_classe_ecole")
  @@map("classes")
}

model Inscription {
  id             Int    @id @default(autoincrement())
  id_eleve       Int
  id_classe      Int
  annee_scolaire String @db.VarChar(20)
  eleve          User   @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "inscriptions_ibfk_1")
  classe         Class  @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "inscriptions_ibfk_2")

  @@index([id_classe], map: "id_classe")
  @@index([id_eleve], map: "id_eleve")
  @@map("inscriptions")
}

model Paiement {
  id             Int           @id @default(autoincrement())
  id_utilisateur Int
  montant        Decimal       @db.Decimal(15, 2)
  status         PaymentStatus @default(en_attente)
  type           PaymentType
  date_paiement  DateTime      @default(now()) @db.Timestamp(0)
  utilisateur    User          @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "paiements_ibfk_1")

  @@index([id_utilisateur], map: "id_utilisateur")
  @@map("paiements")
}

model Absence {
  id           Int              @id @default(autoincrement())
  id_eleve     Int
  date_absence DateTime         @db.Date
  statut       absences_statut? @default(non_justifie)
  motif        String?          @db.Text
  users        User             @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "absences_ibfk_1")

  @@index([id_eleve], map: "id_eleve")
  @@map("absences")
}

model Admin {
  IDadmin      Int    @id @default(autoincrement())
  email        String @db.VarChar(255)
  mot_de_passe String @db.VarChar(255)

  @@map("admin")
}

model Eleve {
  IDeleves Int @id @default(autoincrement())

  @@map("eleves")
}

model Enseignant {
  IDenseign Int @id @default(autoincrement())

  @@map("enseignants")
}

model Parent {
  IDparents Int @id @default(autoincrement())

  @@map("parents")
}

model abonnements {
  id                     Int       @id @default(autoincrement())
  id_ecole               Int
  stripe_subscription_id String?   @db.VarChar(255)
  status                 String?   @db.VarChar(50)
  current_period_end     DateTime? @db.Timestamp(0)
  ecoles                 ecoles    @relation(fields: [id_ecole], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "abonnements_ibfk_1")

  @@index([id_ecole], map: "id_ecole")
}

model ai_insights {
  id              Int      @id @default(autoincrement())
  id_utilisateur  Int
  type            String   @db.VarChar(50)
  message         String   @db.Text
  score_confiance Decimal? @db.Decimal(3, 2)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  users           User     @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ai_insights_ibfk_1")

  @@index([id_utilisateur], map: "id_utilisateur")
}

model annonces {
  id            Int            @id @default(autoincrement())
  titre         String         @db.VarChar(255)
  message       String         @db.Text
  cible         annonces_cible @default(tous)
  id_auteur     Int
  date_creation DateTime       @default(now()) @db.Timestamp(0)
  users         User           @relation(fields: [id_auteur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "annonces_ibfk_1")

  @@index([id_auteur], map: "id_auteur")
}

model badges {
  id            Int            @id @default(autoincrement())
  nom           String         @db.VarChar(100)
  description   String?        @db.Text
  icon_name     String?        @default("Award") @db.VarChar(50)
  points_requis Int?           @default(0)
  eleve_badges  eleve_badges[]
}

model ecoles {
  id                 Int           @id @default(autoincrement())
  nom                String        @db.VarChar(100)
  subdomain          String?       @unique(map: "subdomain") @db.VarChar(50)
  logo_url           String?       @db.VarChar(255)
  stripe_customer_id String?       @db.VarChar(255)
  plan               ecoles_plan?  @default(gratuit)
  database_url       String?       @db.VarChar(512)
  db_status          String        @default("ready") @db.VarChar(20)
  created_at         DateTime      @default(now()) @db.Timestamp(0)
  abonnements        abonnements[]
  classes            Class[]
  users              User[]
}

model eleve_badges {
  id             Int      @id @default(autoincrement())
  id_eleve       Int
  id_badge       Int
  date_obtention DateTime @default(now()) @db.Timestamp(0)
  users          User     @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "eleve_badges_ibfk_1")
  badges         badges   @relation(fields: [id_badge], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "eleve_badges_ibfk_2")

  @@index([id_badge], map: "id_badge")
  @@index([id_eleve], map: "id_eleve")
}

model emplois_du_temps {
  id            Int                   @id @default(autoincrement())
  id_classe     Int
  id_enseignant Int
  matiere       String                @db.VarChar(100)
  jour          emplois_du_temps_jour
  heure_debut   DateTime              @db.Time(0)
  heure_fin     DateTime              @db.Time(0)
  salle         String?               @db.VarChar(50)
  classes       Class                 @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "emplois_du_temps_ibfk_1")
  users         User                  @relation(fields: [id_enseignant], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "emplois_du_temps_ibfk_2")

  @@index([id_classe], map: "id_classe")
  @@index([id_enseignant], map: "id_enseignant")
}

model evaluations {
  id        Int                    @id @default(autoincrement())
  id_classe Int
  matiere   String                 @db.VarChar(100)
  date_eval DateTime               @db.Date
  type_eval evaluations_type_eval? @default(devoir)
  bareme    Int?                   @default(20)
  periode   String?                @db.VarChar(50)
  classes   Class                  @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "evaluations_ibfk_1")
  notes     notes[]

  @@index([id_classe], map: "id_classe")
}

model notes {
  id            Int         @id @default(autoincrement())
  id_evaluation Int
  id_eleve      Int
  valeur        Decimal     @db.Decimal(4, 2)
  commentaire   String?     @db.Text
  evaluations   evaluations @relation(fields: [id_evaluation], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notes_ibfk_1")
  users         User        @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notes_ibfk_2")

  @@index([id_eleve], map: "id_eleve")
  @@index([id_evaluation], map: "id_evaluation")
}

model parcours_scolaires {
  id               Int                          @id @default(autoincrement())
  id_eleve         Int
  annee_scolaire   String                       @db.VarChar(20)
  classe_nom       String                       @db.VarChar(50)
  moyenne_generale Decimal?                     @db.Decimal(4, 2)
  resultat         parcours_scolaires_resultat? @default(Admis)
  observations     String?                      @db.Text
  users            User                         @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "parcours_scolaires_ibfk_1")

  @@index([id_eleve], map: "id_eleve")
}

model settings {
  id       Int     @id @default(autoincrement())
  key_name String  @unique(map: "key_name") @db.VarChar(50)
  value    String? @db.Text
}

enum Role {
  admin
  teacher
  parent
  student
}

enum PaymentStatus {
  paye
  en_attente
  annule
}

enum PaymentType {
  scolarite
  inscription
  examen
}

enum absences_statut {
  justifie
  non_justifie
  en_attente
}

enum annonces_cible {
  tous
  enseignants
  parents
  eleves
}

enum emplois_du_temps_jour {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi
}

enum evaluations_type_eval {
  devoir
  examen
  controle
}

enum ecoles_plan {
  gratuit
  standard
  premium
}

enum parcours_scolaires_resultat {
  Admis
  Redoublant
  Exclu
  Transfert
}
