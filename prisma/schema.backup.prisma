generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model abonnements {
  id                     Int       @id @default(autoincrement())
  id_ecole               Int
  stripe_subscription_id String?
  status                 String?
  current_period_end     DateTime?
  ecoles                 ecoles    @relation(fields: [id_ecole], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "abonnements_ibfk_1")

  @@index([id_ecole], map: "id_ecole")
}

model absences {
  id           Int              @id @default(autoincrement())
  id_eleve     Int
  date_absence DateTime
  statut       absences_statut? @default(non_justifie)
  motif        String?
  users        users            @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "absences_ibfk_1")

  @@index([id_eleve], map: "id_eleve")
}

model admin {
  IDadmin      Int    @id @default(autoincrement())
  email        String
  mot_de_passe String
}

model ai_insights {
  id              Int      @id @default(autoincrement())
  id_utilisateur  Int
  type            String
  message         String
  score_confiance Decimal?
  created_at      DateTime @default(now())
  users           users    @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ai_insights_ibfk_1")

  @@index([id_utilisateur], map: "id_utilisateur")
}

model annonces {
  id            Int            @id @default(autoincrement())
  titre         String
  message       String
  cible         annonces_cible @default(tous)
  id_auteur     Int
  date_creation DateTime       @default(now())
  users         users          @relation(fields: [id_auteur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "annonces_ibfk_1")

  @@index([id_auteur], map: "id_auteur")
}

model badges {
  id            Int            @id @default(autoincrement())
  nom           String
  description   String?
  icon_name     String?        @default("Award")
  points_requis Int?           @default(0)
  eleve_badges  eleve_badges[]
}

model classes {
  id               Int                @id @default(autoincrement())
  id_ecole         Int?
  nom              String
  niveau           String
  created_at       DateTime           @default(now())
  ecoles           ecoles?            @relation(fields: [id_ecole], references: [id], onUpdate: Restrict, map: "fk_classe_ecole")
  emplois_du_temps emplois_du_temps[]
  evaluations      evaluations[]
  inscriptions     inscriptions[]

  @@index([id_ecole], map: "fk_classe_ecole")
}

model ecoles {
  id                 Int           @id @default(autoincrement())
  nom                String
  subdomain          String?       @unique(map: "subdomain")
  logo_url           String?
  stripe_customer_id String?
  plan               ecoles_plan?  @default(gratuit)
  database_url       String?
  db_status          String        @default("ready")
  created_at         DateTime      @default(now())
  abonnements        abonnements[]
  classes            classes[]
  users              users[]
}

model eleve_badges {
  id             Int      @id @default(autoincrement())
  id_eleve       Int
  id_badge       Int
  date_obtention DateTime @default(now())
  users          users    @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "eleve_badges_ibfk_1")
  badges         badges   @relation(fields: [id_badge], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "eleve_badges_ibfk_2")

  @@index([id_badge], map: "id_badge")
  @@index([id_eleve], map: "id_eleve")
}

model eleves {
  IDeleves Int @id @default(autoincrement())
}

model emplois_du_temps {
  id            Int                   @id @default(autoincrement())
  id_classe     Int
  id_enseignant Int
  matiere       String
  jour          emplois_du_temps_jour
  heure_debut   DateTime
  heure_fin     DateTime
  salle         String?
  classes       classes               @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "emplois_du_temps_ibfk_1")
  users         users                 @relation(fields: [id_enseignant], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "emplois_du_temps_ibfk_2")

  @@index([id_classe], map: "id_classe")
  @@index([id_enseignant], map: "id_enseignant")
}

model enseignants {
  IDenseign Int @id @default(autoincrement())
}

model evaluations {
  id        Int                    @id @default(autoincrement())
  id_classe Int
  matiere   String
  date_eval DateTime
  type_eval evaluations_type_eval? @default(devoir)
  bareme    Int?                   @default(20)
  periode   String?
  classes   classes                @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "evaluations_ibfk_1")
  notes     notes[]

  @@index([id_classe], map: "id_classe")
}

model inscriptions {
  id             Int     @id @default(autoincrement())
  id_eleve       Int
  id_classe      Int
  annee_scolaire String
  users          users   @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "inscriptions_ibfk_1")
  classes        classes @relation(fields: [id_classe], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "inscriptions_ibfk_2")

  @@index([id_classe], map: "id_classe")
  @@index([id_eleve], map: "id_eleve")
}

model messages {
  id                                    Int      @id @default(autoincrement())
  id_expediteur                         Int
  id_destinataire                       Int
  contenu                               String
  lu                                    Boolean  @default(false)
  created_at                            DateTime @default(now())
  users_messages_id_destinataireTousers users    @relation("messages_id_destinataireTousers", fields: [id_destinataire], references: [id], onDelete: Cascade)
  users_messages_id_expediteurTousers   users    @relation("messages_id_expediteurTousers", fields: [id_expediteur], references: [id], onDelete: Cascade)

  @@index([id_destinataire], map: "id_destinataire")
  @@index([id_expediteur], map: "id_expediteur")
}

model notes {
  id            Int         @id @default(autoincrement())
  id_evaluation Int
  id_eleve      Int
  valeur        Decimal
  commentaire   String?
  evaluations   evaluations @relation(fields: [id_evaluation], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notes_ibfk_1")
  users         users       @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notes_ibfk_2")

  @@index([id_eleve], map: "id_eleve")
  @@index([id_evaluation], map: "id_evaluation")
}

model paiements {
  id             Int              @id @default(autoincrement())
  id_utilisateur Int
  montant        Decimal
  status         paiements_status @default(en_attente)
  type           paiements_type
  date_paiement  DateTime         @default(now())
  users          users            @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "paiements_ibfk_1")

  @@index([id_utilisateur], map: "id_utilisateur")
}

model parcours_scolaires {
  id               Int                          @id @default(autoincrement())
  id_eleve         Int
  annee_scolaire   String
  classe_nom       String
  moyenne_generale Decimal?
  resultat         parcours_scolaires_resultat? @default(Admis)
  observations     String?
  users            users                        @relation(fields: [id_eleve], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "parcours_scolaires_ibfk_1")

  @@index([id_eleve], map: "id_eleve")
}

model parent_eleve {
  id                                  Int   @id @default(autoincrement())
  id_parent                           Int
  id_eleve                            Int
  users_parent_eleve_id_eleveTousers  users @relation("parent_eleve_id_eleveTousers", fields: [id_eleve], references: [id], onDelete: Cascade)
  users_parent_eleve_id_parentTousers users @relation("parent_eleve_id_parentTousers", fields: [id_parent], references: [id], onDelete: Cascade)

  @@index([id_eleve], map: "id_eleve")
  @@index([id_parent], map: "id_parent")
}

model parents {
  IDparents Int @id @default(autoincrement())
}

model settings {
  id       Int     @id @default(autoincrement())
  key_name String  @unique(map: "key_name")
  value    String?
}

model users {
  id                                         Int                  @id @default(autoincrement())
  id_ecole                                   Int?
  nom                                        String
  email                                      String               @unique(map: "email")
  password                                   String
  role                                       users_role
  matiere                                    String?
  points                                     Int                  @default(0)
  niveau                                     Int                  @default(1)
  created_at                                 DateTime             @default(now())
  absences                                   absences[]
  ai_insights                                ai_insights[]
  annonces                                   annonces[]
  eleve_badges                               eleve_badges[]
  emplois_du_temps                           emplois_du_temps[]
  inscriptions                               inscriptions[]
  messages_messages_id_destinataireTousers   messages[]           @relation("messages_id_destinataireTousers")
  messages_messages_id_expediteurTousers     messages[]           @relation("messages_id_expediteurTousers")
  notes                                      notes[]
  paiements                                  paiements[]
  parcours_scolaires                         parcours_scolaires[]
  parent_eleve_parent_eleve_id_eleveTousers  parent_eleve[]       @relation("parent_eleve_id_eleveTousers")
  parent_eleve_parent_eleve_id_parentTousers parent_eleve[]       @relation("parent_eleve_id_parentTousers")
  ecoles                                     ecoles?              @relation(fields: [id_ecole], references: [id], onUpdate: Restrict, map: "fk_user_ecole")

  @@index([id_ecole], map: "fk_user_ecole")
}

enum absences_statut {
  justifie
  non_justifie
  en_attente
}

enum annonces_cible {
  tous
  enseignants
  parents
  eleves
}

enum paiements_status {
  paye
  en_attente
  annule
}

enum emplois_du_temps_jour {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi
}

enum evaluations_type_eval {
  devoir
  examen
  controle
}

enum paiements_type {
  scolarite
  inscription
  examen
}

enum ecoles_plan {
  gratuit
  standard
  premium
}

enum parcours_scolaires_resultat {
  Admis
  Redoublant
  Exclu
  Transfert
}

enum users_role {
  admin
  teacher
  parent
  student
}
